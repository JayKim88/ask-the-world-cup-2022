# ── Data seeding (one-time, build-side only — NOT used at runtime) ──
# API-Football (api-sports.io) free key for the 2022 WC snapshot ingest.
API_FOOTBALL_KEY=
# Supabase project URL + SERVICE ROLE key — seeding writes (bypass RLS).
# Service role is a SECRET: build-side only, never expose to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (runtime, client-visible) — dedicated isolated project (PRD §4.1) ──
# anon URL/key are safe to expose; the real boundary is the read-only role + RPC.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── LLM (NL → SQL) ──
# Default provider/model for text-to-SQL. The user's own API key is supplied
# per-request via BYOK (browser-stored), never persisted server-side.
TEXT2SQL_MODEL=claude-sonnet-5
